generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  BRANCH_MANAGER
  CASHIER
  TECHNICIAN
  DEVELOPER
}

enum RepairStatus {
  PENDING
  DIAGNOSING
  WAITING_PARTS
  IN_PROGRESS
  COMPLETED
  RELEASED
  CANCELLED
}

enum PaymentMethod {
  CASH
  GCASH
}

enum SaleType {
  POS
  REPAIR
}

enum NotificationType {
  LOW_STOCK
  NEW_REPAIR
  COMPLETED_REPAIR
  SUBSCRIPTION_REMINDER
  BRANCH_ANNOUNCEMENT
}

model Branch {
  id              String           @id @default(cuid())
  slug            String           @unique
  name            String
  address         String
  contactNumber   String?
  users           User[]
  stocks          Stock[]
  sales           Sale[]
  repairs         RepairTicket[]
  expenses        Expense[]
  notifications   Notification[]
  transfersFrom   StockTransfer[]  @relation("TransferFrom")
  transfersTo     StockTransfer[]  @relation("TransferTo")
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model User {
  id            String         @id @default(cuid())
  name          String
  email         String         @unique
  passwordHash  String
  role          Role
  branchId      String?
  branch        Branch?        @relation(fields: [branchId], references: [id])
  sales         Sale[]
  repairs       RepairTicket[] @relation("TechnicianTickets")
  expenses      Expense[]
  notifications Notification[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Product {
  id             String       @id @default(cuid())
  name           String
  sku            String       @unique
  barcode        String       @unique
  category       String
  brand          String
  compatibility  String
  costPrice      Decimal      @db.Decimal(10, 2)
  sellingPrice   Decimal      @db.Decimal(10, 2)
  lowStockAlert  Int          @default(5)
  stocks         Stock[]
  saleItems      SaleItem[]
  repairParts    RepairPart[]
  transfers      StockTransfer[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Stock {
  id        String   @id @default(cuid())
  productId String
  branchId  String
  quantity  Int      @default(0)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  branch    Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  updatedAt DateTime @updatedAt

  @@unique([productId, branchId])
}

model StockTransfer {
  id           String   @id @default(cuid())
  productId    String
  fromBranchId String
  toBranchId   String
  quantity     Int
  notes        String?
  product      Product  @relation(fields: [productId], references: [id])
  fromBranch   Branch   @relation("TransferFrom", fields: [fromBranchId], references: [id])
  toBranch     Branch   @relation("TransferTo", fields: [toBranchId], references: [id])
  createdAt    DateTime @default(now())
}

model Sale {
  id             String        @id @default(cuid())
  receiptNumber  String        @unique
  type           SaleType
  branchId       String
  cashierId      String
  paymentMethod  PaymentMethod
  subtotal       Decimal       @db.Decimal(10, 2)
  discount       Decimal       @default(0) @db.Decimal(10, 2)
  total          Decimal       @db.Decimal(10, 2)
  amountTendered Decimal       @default(0) @db.Decimal(10, 2)
  branch         Branch        @relation(fields: [branchId], references: [id])
  cashier        User          @relation(fields: [cashierId], references: [id])
  items          SaleItem[]
  repairTicket   RepairTicket?
  createdAt      DateTime      @default(now())
}

model SaleItem {
  id        String  @id @default(cuid())
  saleId    String
  productId String
  quantity  Int
  unitPrice Decimal @db.Decimal(10, 2)
  sale      Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])
}

model Customer {
  id        String         @id @default(cuid())
  name      String
  phone     String?
  email     String?
  address   String?
  repairs   RepairTicket[]
  createdAt DateTime       @default(now())
}

model RepairTicket {
  id                  String       @id @default(cuid())
  ticketNumber        String       @unique
  customerId          String
  branchId            String
  technicianId        String?
  deviceBrand         String
  deviceModel         String
  problemDescription  String
  diagnosis           String?
  status              RepairStatus @default(PENDING)
  laborFee            Decimal      @default(0) @db.Decimal(10, 2)
  partsTotal          Decimal      @default(0) @db.Decimal(10, 2)
  customerSignature   String?
  beforePhotoUrl      String?
  afterPhotoUrl       String?
  warrantyUntil       DateTime?
  saleId              String?      @unique
  customer            Customer     @relation(fields: [customerId], references: [id])
  branch              Branch       @relation(fields: [branchId], references: [id])
  technician          User?        @relation("TechnicianTickets", fields: [technicianId], references: [id])
  parts               RepairPart[]
  sale                Sale?        @relation(fields: [saleId], references: [id])
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
}

model RepairPart {
  id             String       @id @default(cuid())
  repairTicketId String
  productId      String
  quantity       Int
  unitPrice      Decimal      @db.Decimal(10, 2)
  repairTicket   RepairTicket @relation(fields: [repairTicketId], references: [id], onDelete: Cascade)
  product        Product      @relation(fields: [productId], references: [id])
}

model Expense {
  id           String   @id @default(cuid())
  category     String
  amount       Decimal  @db.Decimal(10, 2)
  notes        String?
  date         DateTime
  branchId     String
  recordedById String
  branch       Branch   @relation(fields: [branchId], references: [id])
  recordedBy   User     @relation(fields: [recordedById], references: [id])
  createdAt    DateTime @default(now())
}

model Notification {
  id        String           @id @default(cuid())
  type      NotificationType
  title     String
  message   String
  unread    Boolean          @default(true)
  branchId  String?
  userId    String?
  branch    Branch?          @relation(fields: [branchId], references: [id])
  user      User?            @relation(fields: [userId], references: [id])
  createdAt DateTime         @default(now())
}
